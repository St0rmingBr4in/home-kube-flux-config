{
  "extends": [
    "config:best-practices"
  ],
  "minimumReleaseAge": "30 days",
  "packageRules": [
    {
      "description": "Auto-merge minor and patch updates when CI passes",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Group Go toolchain updates: go.mod directive and golang container images must move together",
      "matchPackageNames": ["go", "golang"],
      "groupName": "go toolchain"
    },
    {
      "description": "Group Vault image updates across workflow templates (vault-login in common.yaml and docker-creds in docker-build.yaml)",
      "matchPackageNames": ["hashicorp/vault"],
      "groupName": "hashicorp vault image"
    },
    {
      "description": "Group alpine image updates across app-health-hook jobs",
      "matchPackageNames": ["alpine"],
      "groupName": "alpine image"
    }
  ],
  "argocd": {
    "managerFilePatterns": ["/\\.yaml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update k3s version in Ansible vars",
      "managerFilePatterns": ["/^ansible/inventory/group_vars/k3s_cluster/vars\\.yaml$/"],
      "matchStrings": [
        "k3s_release_version: \"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "k3s-io/k3s",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update Helm chart versions in ArgoCD ApplicationSet list generators (HTTPS registries)",
      "managerFilePatterns": ["/^argocd\\/applications\\/.+\\/applicationset\\.yaml$/"],
      "matchStrings": [
        "- name: [^\\n]+\\n\\s+chart: (?<depName>[^\\s\\n]+)\\n\\s+chartVersion: (?<currentValue>[^\\s\\n]+)[\\s\\S]*?repoURL: (?<registryUrl>https?://[^\\s\\n]+)"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Update TrueCharts OCI Helm chart versions in media ApplicationSets",
      "managerFilePatterns": ["/^argocd\\/applications\\/media\\/.+\\/applicationset\\.yaml$/"],
      "matchStrings": [
        "- name: [^\\n]+\\n\\s+chart: (?<depName>[^\\s\\n]+)\\n\\s+chartVersion: (?<currentValue>[^\\s\\n]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "truecharts/{{depName}}",
      "registryUrlTemplate": "https://oci.trueforge.org"
    }
  ]
}
